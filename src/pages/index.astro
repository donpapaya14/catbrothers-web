---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/content/ArticleCard.astro';
import { getCollection } from 'astro:content';
import { CATEGORIES } from '../utils/categories';
import type { Category } from '../utils/categories';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const latestPosts = allPosts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 6);

const categories = Object.entries(CATEGORIES) as [Category, (typeof CATEGORIES)[Category]][];
---

<BaseLayout title="CatBrothers" description="Editorial cat magazine. Vet-reviewed cat health, nutrition, behavior and fun facts — no myths, no clickbait.">
  <!-- Hero -->
  <section class="hero">
    <div class="hero__media" aria-hidden="true">
      <img
        src="https://images.pexels.com/photos/1741205/pexels-photo-1741205.jpeg?auto=compress&cs=tinysrgb&w=1600"
        alt=""
        loading="eager"
        decoding="async"
      />
    </div>
    <div class="container hero__inner hero-grid">
      <div class="hero-text">
        <div class="eyebrow">An editorial cat magazine</div>
        <h1 class="display hero__title">
          Cats,<br />
          <em>seriously loved</em>
        </h1>
        <p class="lede hero__subtitle">
          Vet-reviewed health, honest nutrition guides, and behavior science that actually
          works at home. No myths, no clickbait — just what makes your cat thrive.
        </p>
        <div class="hero__actions">
          <a href="/blog" class="btn-primary">Read articles &rarr;</a>
          <a href="#categories" class="btn-ghost">Explore categories</a>
        </div>

        <div class="pop-chips" aria-label="Popular topics">
          <span class="pop-chips-label">Popular</span>
          <a href="/categoria/cat-health" class="pop-chip">Cat health</a>
          <a href="/categoria/nutrition" class="pop-chip">Nutrition</a>
          <a href="/categoria/behavior" class="pop-chip">Behavior</a>
          <a href="/categoria/entertainment" class="pop-chip">Fun facts</a>
          <a href="/categoria/products" class="pop-chip">Toys &amp; gear</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Latest Articles -->
  <section class="section">
    <div class="container">
      <div class="section__header">
        <div>
          <div class="eyebrow">Recent</div>
          <h2 class="section-title">Latest articles</h2>
        </div>
        <a href="/blog" class="section__link">See all &rarr;</a>
      </div>
      <div class="articles-grid">
        {latestPosts.map(post => (
          <ArticleCard
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            category={post.data.category}
            slug={post.id}
            image={post.data.image}
            readingTime={post.data.readingTime}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Categories -->
  <section id="categories" class="section section--alt">
    <div class="container">
      <div style="text-align:center;margin-bottom:36px">
        <div class="eyebrow" style="justify-content:center">Explore</div>
        <h2 class="section-title">By category</h2>
      </div>
      <div class="categories-grid">
        {categories.map(([key, cat]) => (
          <a href={`/categoria/${key}`} class={`cat-card cat-card--${key}`}>
            <h3>{cat.name}</h3>
            <p>{cat.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Cat Facts (dark stats) -->
  <section class="section section--dark">
    <div class="container">
      <div style="text-align:center;margin-bottom:32px">
        <div class="eyebrow" style="justify-content:center">Cat facts</div>
        <h2 class="section-title">Things you probably <em class="script-accent">didn't know</em></h2>
      </div>
      <div class="fact-stats">
        <div class="fact-stat">
          <span class="fact-stat__num">70%</span>
          <span class="fact-stat__label">of a cat's life is spent sleeping or resting</span>
        </div>
        <div class="fact-stat">
          <span class="fact-stat__num">32</span>
          <span class="fact-stat__label">muscles in each cat ear, allowing 180&deg; rotation</span>
        </div>
        <div class="fact-stat">
          <span class="fact-stat__num">100+</span>
          <span class="fact-stat__label">distinct vocal sounds in a domestic cat's repertoire</span>
        </div>
        <div class="fact-stat">
          <span class="fact-stat__num">5x</span>
          <span class="fact-stat__label">better low-light vision than humans</span>
        </div>
      </div>
    </div>
  </section>

  <!-- YouTube CTA -->
  <section class="section">
    <div class="container yt-cta">
      <div class="yt-cta__inner">
        <div class="eyebrow" style="justify-content:center">Also on YouTube</div>
        <h2 class="section-title">Cat tips in <em>60 seconds</em></h2>
        <p class="lede" style="margin:14px auto 24px;max-width:520px;text-align:center">
          Daily shorts with vet-reviewed sources. Quick, science-backed cat content.
        </p>
        <a href="https://youtube.com/@CATBROTHERS2" target="_blank" rel="noopener" class="btn-primary btn--lg">
          Visit channel &rarr;
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero-text { max-width: 760px; }
  .hero__title em { font-style: italic; color: var(--accent); }

  /* Per-category accent edge */
  .cat-card--cat-health     { box-shadow: inset 4px 0 0 var(--terracotta), var(--shadow-md); }
  .cat-card--nutrition      { box-shadow: inset 4px 0 0 #B5651D, var(--shadow-md); }
  .cat-card--behavior       { box-shadow: inset 4px 0 0 #6B4423, var(--shadow-md); }
  .cat-card--products       { box-shadow: inset 4px 0 0 #8B5A2B, var(--shadow-md); }
  .cat-card--entertainment  { box-shadow: inset 4px 0 0 var(--accent), var(--shadow-md); }

  .yt-cta {
    text-align: center;
  }
  .yt-cta__inner { max-width: 720px; margin: 0 auto; }

  @media (max-width: 600px) {
    .hero__actions { flex-direction: column; align-items: flex-start; }
    .hero__actions .btn-primary,
    .hero__actions .btn-ghost { width: 100%; justify-content: center; }
  }
</style>
